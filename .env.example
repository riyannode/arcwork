# ═══════════════════════════════════════════════════════════════════════════════
# ArcLayer Environment Variables
# Copy to .env.local and fill in your values.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ─── Arc Testnet RPC ──────────────────────────────────────────────────────────
NEXT_PUBLIC_ARC_RPC_URL=https://rpc.drpc.testnet.arc.network
NEXT_PUBLIC_ARC_USDC_ADDRESS=0x3600000000000000000000000000000000000000

# ─── x402 Facilitator (Arc Native) ───────────────────────────────────────────
X402_FACILITATOR_ENABLED=true
X402_DEFAULT_PAY_TO=0xYourReceiverAddress
X402_RECEIVER_ADDRESS=0xYourReceiverAddress
X402_RELAYER_PRIVATE_KEY=0xYourRelayerPrivateKey
X402_SETTLE_MODE=self-hosted
X402_REQUIREMENT_TTL_SECONDS=300
X402_RESPONSE_CACHE_TTL_SECONDS=86400
X402_VERIFY_TIMEOUT_MS=10000

# ─── x402 Circle Gateway ─────────────────────────────────────────────────────
# Set to "true" to enable Circle Gateway payment mode alongside Arc Native.
X402_GATEWAY_ENABLED=false
# CAIP-2 network identifier for Arc Testnet used by Circle SDK.
X402_GATEWAY_NETWORK=eip155:5042002
# Circle Gateway facilitator base URL (testnet).
X402_GATEWAY_FACILITATOR_URL=https://gateway-api-testnet.circle.com
# GatewayWallet contract address on Arc Testnet (from Circle SDK CHAIN_CONFIGS).
X402_GATEWAY_WALLET_ADDRESS=0x0077777d7EBA4688BDeF3E311b846F25870A19B9
# Seller/receiver address for Gateway settlements (same as Arc Native payTo).
X402_PAY_TO=0xYourReceiverAddress

# ─── Agent Executor (OpenAI-compatible) ───────────────────────────────────────
ARCLAYER_AGENT_ENDPOINT=https://your-llm-proxy.example.com/v1
ARCLAYER_AGENT_MODEL=gpt-4o
ARCLAYER_AGENT_API_KEY=your-a...-key

# ─── A2A Autonomous Runner ───────────────────────────────────────────────────
# Reasoning mode: 'deterministic' (default, no LLM) or 'llm' (calls LLM gateway)
A2A_REASONING_MODE=deterministic
# Runner interval in ms (default: 900000 = 15 minutes)
A2A_RUNNER_INTERVAL_MS=900000
# Assets to track (comma-separated)
A2A_MARKET_ASSETS=BTC,ETH
#
# ─── A2A Trade History Storage ───────────────────────────────────────────────
# Storage strategy:
#   - Primary: Supabase (when SUPABASE_URL/NEXT_PUBLIC_SUPABASE_URL +
#     SUPABASE_SERVICE_ROLE_KEY are set above). Required for production where
#     the runner (VPS) and frontend/API (Vercel) are split — Vercel cannot read
#     a VPS-local JSONL file.
#   - Fallback: JSONL at A2A_TRADES_PATH (local/dev or when Supabase is down).
# Run apps/console/supabase/migrations/010_a2a_trades.sql to create the table.
# A2A_TRADES_PATH=./data/a2a-trades.jsonl
# PnL resolver grace period in seconds after window close (default: 120)
# A2A_PNL_GRACE_SEC=120
# Optional: override LLM endpoint/model for A2A specifically
# A2A_LLM_ENDPOINT=http://localhost:20128/v1
# A2A_LLM_MODEL=cx/gpt-5.5
# A2A_LLM_API_KEY=***
# A2A_LLM_TIMEOUT_MS=20000

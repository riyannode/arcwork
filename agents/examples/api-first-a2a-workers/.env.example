# ArcLayer API-first A2A workers. Copy to .env and fill locally. Do not commit .env.
ARCLAYER_BASE_URL=https://arclayers.xyz
ARCLAYER_AGENT_ID=
ARCLAYER_API_KEY=[REDACTED]

# Arc Testnet
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_RPC_FALLBACK_URL=https://rpc.drpc.testnet.arc.network
WORKER_PRIVATE_KEY=
EVALUATOR_PRIVATE_KEY=

# Runtime role: creator | submitter | evaluator
WORKER_ROLE=submitter
POLL_INTERVAL_MS=600000
DRY_RUN=true
MAX_JOBS_PER_RUN=1
CONCURRENCY=1
MAX_LLM_CALLS_PER_JOB=1

# LLM: OpenAI-compatible Pioneer endpoint
LLM_PROVIDER=pioneer
PIONEER_BASE_URL=https://agent.pioneer.ai
PIONEER_API_KEY=[REDACTED]
PIONEER_MODEL=arc-a2a-worker
MAX_TOKENS=800
TEMPERATURE=0.2
DAILY_USD_CAP=5

# Creator is intentionally API-only; x402 job creation is disabled unless explicitly enabled.
ENABLE_X402_CREATE_JOB=false
CREATOR_JOB_TITLE=API-first A2A worker request
CREATOR_JOB_DESCRIPTION=Produce a concise ArcLayer A2A deliverable.
CREATOR_JOB_CATEGORY=general
CREATOR_JOB_ROLE_ID=submitter

# On-chain receipt verification flow. Keep false unless wallet and ERC-8183 job ids are configured.
ENABLE_ONCHAIN_SUBMIT=true
ENABLE_ONCHAIN_COMPLETE=true
